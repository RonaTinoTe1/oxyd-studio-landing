---
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Blog — OXYD Studio | Automatisation IA, outils sur mesure</title>
  <meta name="description" content="Articles sur l'automatisation IA, les outils sur mesure, et les meilleures pratiques pour les PME et startups. Par OXYD Studio." />
  <link rel="canonical" href="https://oxyd.studio/blog/" />
  <meta property="og:title" content="Blog — OXYD Studio" />
  <meta property="og:description" content="Articles sur l'automatisation IA et les outils sur mesure pour PME." />
  <meta property="og:url" content="https://oxyd.studio/blog/" />
  <meta property="og:type" content="website" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="stylesheet" href="/style.css" />
  <style>
    .blog-card { background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06); border-radius: 16px; padding: 24px; transition: all 0.2s; }
    .blog-card:hover { background: rgba(255,255,255,0.06); border-color: rgba(244,81,30,0.3); }
    .blog-tag { display: inline-block; padding: 2px 10px; border-radius: 20px; font-size: 11px; background: rgba(244,81,30,0.1); color: #F4511E; }
  </style>
</head>
<body>
  <nav class="navbar" id="navbar">
    <div class="container">
      <a href="/" class="navbar-logo">
        <span class="logo-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="18" height="18">
            <polygon points="12 2 2 7 12 12 22 7 12 2" />
          </svg>
        </span>
        Oxyd Studio
      </a>
      <div class="navbar-links">
        <a href="/#product">Produit</a>
        <a href="/#pricing">Tarifs</a>
        <a href="/blog" style="color: #F4511E;">Blog</a>
        <a href="/#contact">Contact</a>
      </div>
    </div>
  </nav>

  <main style="padding-top: 120px; max-width: 800px; margin: 0 auto; padding-left: 20px; padding-right: 20px; min-height: 80vh;">
    <h1 style="font-family: var(--font); font-size: 2.5rem; font-weight: 800; margin-bottom: 8px;">Blog</h1>
    <p style="color: var(--text-secondary); margin-bottom: 48px; font-size: 1.1rem;">Automatisation IA, outils sur mesure, retours d'expérience.</p>

    <div style="display: flex; flex-direction: column; gap: 24px;">
      {posts.map(post => (
        <a href={`/blog/${post.id}/`} class="blog-card" style="text-decoration: none; color: inherit;">
          <div style="display: flex; gap: 8px; margin-bottom: 12px; flex-wrap: wrap;">
            {post.data.tags.map(tag => (
              <span class="blog-tag">{tag}</span>
            ))}
          </div>
          <h2 style="font-size: 1.4rem; font-weight: 700; margin-bottom: 8px; color: var(--text-primary);">{post.data.title}</h2>
          <p style="color: var(--text-secondary); font-size: 0.95rem; line-height: 1.6; margin-bottom: 12px;">{post.data.description}</p>
          <time style="color: var(--text-muted); font-size: 0.8rem;" datetime={post.data.pubDate.toISOString()}>
            {post.data.pubDate.toLocaleDateString('fr-FR', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
        </a>
      ))}
    </div>
  </main>

  <footer style="text-align: center; padding: 48px 20px; color: var(--text-muted); font-size: 0.85rem;">
    <p>&copy; 2026 OXYD Studio · <a href="/" style="color: #F4511E;">oxyd.studio</a></p>
  </footer>
</body>
</html>
