---
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{post.data.title} — OXYD Studio</title>
  <meta name="description" content={post.data.description} />
  <link rel="canonical" href={`https://oxyd.studio/blog/${post.id}/`} />
  <meta property="og:title" content={`${post.data.title} — OXYD Studio`} />
  <meta property="og:description" content={post.data.description} />
  <meta property="og:url" content={`https://oxyd.studio/blog/${post.id}/`} />
  <meta property="og:type" content="article" />
  <meta property="og:image" content="https://oxyd.studio/og-image.png" />
  <meta property="article:published_time" content={post.data.pubDate.toISOString()} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={post.data.title} />
  <meta name="twitter:description" content={post.data.description} />
  <meta name="twitter:image" content="https://oxyd.studio/og-image.png" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": post.data.title,
    "description": post.data.description,
    "url": `https://oxyd.studio/blog/${post.id}/`,
    "datePublished": post.data.pubDate.toISOString(),
    "dateModified": post.data.pubDate.toISOString(),
    "author": {
      "@type": "Person",
      "name": post.data.author,
      "url": "https://oxyd.studio"
    },
    "publisher": {
      "@type": "Organization",
      "name": "OXYD Studio",
      "url": "https://oxyd.studio",
      "logo": {
        "@type": "ImageObject",
        "url": "https://oxyd.studio/og-image.png"
      }
    },
    "image": "https://oxyd.studio/og-image.png",
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": `https://oxyd.studio/blog/${post.id}/`
    },
    "keywords": post.data.tags.join(", "),
    "inLanguage": "fr-FR",
    "isPartOf": {
      "@type": "Blog",
      "name": "OXYD Studio Blog",
      "url": "https://oxyd.studio/blog"
    }
  })} />
  <link rel="stylesheet" href="/style.css" />
  <style>
    .article-content { max-width: 700px; margin: 0 auto; line-height: 1.8; color: var(--text-secondary); }
    .author-box {
      max-width: 700px; margin: 56px auto 0;
      border: 1px solid rgba(255,255,255,0.08); border-radius: 16px;
      padding: 28px 32px; display: flex; gap: 24px; align-items: flex-start;
      background: rgba(255,255,255,0.03);
    }
    .author-avatar {
      width: 56px; height: 56px; border-radius: 50%; flex-shrink: 0;
      background: linear-gradient(135deg, #F4511E, #D43F0D);
      display: flex; align-items: center; justify-content: center;
      font-size: 22px; font-weight: 800; color: #fff; font-family: 'Space Grotesk', sans-serif;
    }
    .author-info { flex: 1; }
    .author-name { font-weight: 700; font-size: 1rem; color: var(--text-primary); margin-bottom: 4px; font-family: 'Space Grotesk', sans-serif; }
    .author-title { font-size: 0.8rem; color: #F4511E; font-family: 'JetBrains Mono', monospace; letter-spacing: 0.04em; margin-bottom: 10px; }
    .author-bio { font-size: 0.92rem; line-height: 1.65; color: var(--text-muted, #9CA3AF); }
    .author-cta {
      display: inline-flex; align-items: center; gap: 6px; margin-top: 14px;
      font-size: 0.82rem; font-weight: 600; color: #F4511E;
      text-decoration: none; font-family: 'JetBrains Mono', monospace; letter-spacing: 0.02em;
    }
    .author-cta:hover { text-decoration: underline; }
    .article-content h2 { font-size: 1.5rem; font-weight: 700; color: var(--text-primary); margin-top: 2.5rem; margin-bottom: 1rem; }
    .article-content h3 { font-size: 1.2rem; font-weight: 600; color: var(--text-primary); margin-top: 2rem; margin-bottom: 0.75rem; }
    .article-content p { margin-bottom: 1.25rem; font-size: 1.05rem; }
    .article-content strong { color: var(--text-primary); }
    .article-content a { color: #F4511E; text-decoration: underline; text-underline-offset: 3px; }
    .article-content ul, .article-content ol { margin-bottom: 1.25rem; padding-left: 1.5rem; }
    .article-content li { margin-bottom: 0.5rem; }
    .article-content hr { border: none; border-top: 1px solid var(--border); margin: 2rem 0; }
    .article-content em { color: var(--text-muted); }
  </style>
  <!-- Privacy-friendly analytics by Plausible -->
  <script async src="https://plausible.io/js/pa-eQmapsJCn9blo_-8Uw8Go.js"></script>
  <script>
    window.plausible=window.plausible||function(){(plausible.q=plausible.q||[]).push(arguments)},plausible.init=plausible.init||function(i){plausible.o=i||{}};
    plausible.init()
  </script>
</head>
<body>
  <nav class="navbar" id="navbar">
    <div class="container">
      <a href="/" class="navbar-logo">
        <span class="logo-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="18" height="18">
            <polygon points="12 2 2 7 12 12 22 7 12 2" />
          </svg>
        </span>
        Oxyd Studio
      </a>
      <div class="navbar-links">
        <a href="/#product">Produit</a>
        <a href="/#pricing">Tarifs</a>
        <a href="/blog" style="color: #F4511E;">Blog</a>
        <a href="/#contact">Contact</a>
      </div>
    </div>
  </nav>

  <main style="padding-top: 120px; padding-left: 20px; padding-right: 20px; padding-bottom: 80px;">
    <article class="article-content">
      <a href="/blog" style="color: var(--text-muted); font-size: 0.85rem; text-decoration: none; display: inline-flex; align-items: center; gap: 6px; margin-bottom: 24px;">
        ← Retour au blog
      </a>
      <h1 style="font-size: 2.2rem; font-weight: 800; color: var(--text-primary); line-height: 1.2; margin-bottom: 16px;">
        {post.data.title}
      </h1>
      <div style="display: flex; align-items: center; gap: 16px; color: var(--text-muted); font-size: 0.85rem; margin-bottom: 40px;">
        <time datetime={post.data.pubDate.toISOString()}>
          {post.data.pubDate.toLocaleDateString('fr-FR', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
        <span>·</span>
        <span>{post.data.author}</span>
        <span>·</span>
        <div style="display: flex; gap: 6px;">
          {post.data.tags.map(tag => (
            <span style="padding: 2px 8px; border-radius: 12px; font-size: 11px; background: rgba(244,81,30,0.1); color: #F4511E;">{tag}</span>
          ))}
        </div>
      </div>

      <Content />

    </article>

    <!-- Author box — E-E-A-T trust signal -->
    <div class="author-box">
      <div class="author-avatar">N</div>
      <div class="author-info">
        <div class="author-name">Nathan</div>
        <div class="author-title">Fondateur · OXYD Studio</div>
        <p class="author-bio">
          Je construis des outils IA sur mesure pour aider les PME à automatiser leurs tâches répétitives.
          Basé à Dijon, je diagnostique les process manuels qui coûtent du temps et de l'argent — et je les automatise.
          Chaque article de ce blog est tiré de cas réels ou de recherches terrain.
        </p>
        <a href="/a-propos" class="author-cta">En savoir plus →</a>
      </div>
    </div>

  </main>

  <footer style="text-align: center; padding: 48px 20px; color: var(--text-muted); font-size: 0.85rem;">
    <p>&copy; 2026 OXYD Studio · <a href="/" style="color: #F4511E;">oxyd.studio</a></p>
  </footer>
</body>
</html>
