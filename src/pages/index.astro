  <script is:inline defer src="/_vercel/insights/script.js"></script>

  <style>
    /* ===== RESET & BASE ===== */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:       #0A0A0A;
      --bg2:      #141414;
      --accent:   #F4511E;
      --accent-h: #D43F0D;
      --text:     #FAFAFA;
      --muted:    #6B7280;
      --border:   #2A2A2A;
      --r:        18px;
      --f-display: 'Space Grotesk', sans-serif;
      --f-body:    'Inter', sans-serif;
      --f-mono:    'JetBrains Mono', monospace;
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--f-body);
      font-size: 16px;
      line-height: 1.6;
      overflow-x: hidden;
      -webkit-font-smoothing: antialiased;
    }

    .container {
      max-width: 1100px;
      margin: 0 auto;
      padding: 0 24px;
    }

    /* ===== ANIMATIONS ===== */
    .fade-in {
      opacity: 0;
      transform: translateY(20px);
      transition: opacity 0.5s ease-out, transform 0.5s ease-out;
    }
    .fade-in.visible { opacity: 1; transform: none; }
    .d1 { transition-delay: 0.10s; }
    .d2 { transition-delay: 0.20s; }
    .d3 { transition-delay: 0.30s; }
    .d4 { transition-delay: 0.40s; }

    /* ===== NAVBAR ===== */
    .nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      padding: 14px 0;
      background: rgba(10,10,10,0.88);
      backdrop-filter: blur(14px);
      border-bottom: 1px solid transparent;
      transition: border-color 0.3s;
    }
    .nav.scrolled { border-bottom-color: var(--border); }
    .nav .container { display: flex; align-items: center; justify-content: space-between; }

    .nav-logo {
      display: flex; align-items: center; gap: 10px;
      text-decoration: none; color: var(--text);
      font-family: var(--f-display); font-weight: 700; font-size: 16px;
    }

    .nav-links {
      display: flex; align-items: center; gap: 28px; list-style: none;
    }
    .nav-links a {
      text-decoration: none; color: var(--muted);
      font-size: 14px; font-weight: 500;
      transition: color 0.2s;
    }
    .nav-links a:hover { color: var(--text); }

    /* ===== BUTTONS ===== */
    .btn {
      display: inline-flex; align-items: center; gap: 8px;
      border-radius: 100px; font-family: var(--f-body); font-weight: 600;
      cursor: pointer; text-decoration: none; border: none;
      transition: background 0.2s, transform 0.15s, border-color 0.2s, color 0.2s;
    }
    .btn:active { transform: translateY(1px); }

    .btn-primary {
      background: var(--accent); color: var(--text);
      padding: 14px 32px; font-size: 16px;
    }
    .btn-primary:hover { background: var(--accent-h); transform: translateY(-1px); }

    .btn-sm {
      background: var(--accent); color: var(--text);
      padding: 10px 22px; font-size: 14px;
    }
    .btn-sm:hover { background: var(--accent-h); }

    .btn-ghost {
      background: transparent; color: var(--muted);
      border: 1px solid var(--border);
      padding: 13px 28px; font-size: 15px; font-weight: 500;
    }
    .btn-ghost:hover { border-color: rgba(250,250,250,0.3); color: var(--text); }

    .btn-ghost-sm {
      background: transparent; color: var(--muted);
      border: 1px solid var(--border);
      padding: 10px 22px; font-size: 14px; font-weight: 500;
    }
    .btn-ghost-sm:hover { border-color: rgba(250,250,250,0.3); color: var(--text); }

    .btn-link {
      display: inline-flex; align-items: center; gap: 6px;
      color: var(--accent); text-decoration: none;
      font-size: 15px; font-weight: 500;
      background: none; border: none; cursor: pointer; font-family: var(--f-body);
      transition: gap 0.2s;
    }
    .btn-link:hover { gap: 10px; }

    /* ===== EYEBROW ===== */
    .eyebrow {
      display: inline-block;
      font-family: var(--f-mono); font-size: 11px; font-weight: 500;
      color: var(--accent); letter-spacing: 0.14em; text-transform: uppercase;
      margin-bottom: 16px;
    }

    /* ===== SECTION HEADINGS ===== */
    .section-h2 {
      font-family: var(--f-display);
      font-size: clamp(28px, 4vw, 44px);
      font-weight: 800;
      letter-spacing: -0.03em;
      line-height: 1.1;
      margin-bottom: 16px;
    }

    /* ================================================================
       SECTION 1 — HERO
    ================================================================ */
    .hero {
      min-height: 100vh;
      display: flex; align-items: center;
      position: relative; overflow: hidden;
      padding: 120px 0 80px;
    }

    /* Accent glow — anchored left, behind the title */
    .hero::before {
      content: '';
      position: absolute;
      top: 10%; left: -5%;
      width: 640px; height: 640px;
      background: radial-gradient(ellipse at 30% 50%, rgba(244,81,30,0.13) 0%, transparent 65%);
      pointer-events: none;
    }

    /* Subtle horizontal rule texture */
    .hero::after {
      content: '';
      position: absolute;
      bottom: 0; left: 0; right: 0; height: 1px;
      background: linear-gradient(to right, transparent, var(--border) 30%, var(--border) 70%, transparent);
      pointer-events: none;
    }

    /* SVG grain overlay */
    .hero-grain {
      position: absolute; inset: 0; pointer-events: none; z-index: 1;
    }

    .hero .container {
      position: relative; z-index: 2;
      display: grid;
      grid-template-columns: 1fr;
      gap: 0;
    }

    .hero-content { max-width: 680px; }

    /* Running tag line above h1 */
    .hero-eyebrow {
      display: flex; align-items: center; gap: 10px;
      margin-bottom: 28px;
    }
    .hero-eyebrow-line {
      width: 32px; height: 1px; background: var(--accent);
    }
    .hero-eyebrow span {
      font-family: var(--f-mono); font-size: 11px; font-weight: 500;
      color: var(--accent); letter-spacing: 0.14em; text-transform: uppercase;
    }

    .hero h1 {
      font-family: var(--f-display);
      font-size: clamp(42px, 6vw, 72px);
      font-weight: 800;
      letter-spacing: -0.04em;
      line-height: 1.05;
      color: var(--text);
      margin-bottom: 28px;
    }
    .hero h1 em {
      font-style: normal;
      color: var(--accent);
      position: relative;
    }

    .hero-sub {
      font-size: 17px; line-height: 1.75;
      color: var(--muted); max-width: 500px;
      margin-bottom: 44px;
    }

    .hero-ctas {
      display: flex; align-items: center; gap: 14px;
      flex-wrap: wrap; margin-bottom: 32px;
    }

    /* Social proof strip under CTAs */
    .hero-proof {
      display: flex; align-items: center; gap: 24px;
      flex-wrap: wrap;
    }
    .hp-stat {
      display: flex; align-items: baseline; gap: 5px;
    }
    .hp-stat strong {
      font-family: var(--f-display); font-size: 20px; font-weight: 800;
      color: var(--text); letter-spacing: -0.03em;
    }
    .hp-stat span {
      font-size: 12px; color: var(--muted);
    }
    .hp-divider {
      width: 1px; height: 22px; background: var(--border);
    }

    @keyframes pulse {
      0%,100% { opacity:1; } 50% { opacity:0.35; }
    }

    /* ================================================================
       SECTION 2 — PROBLÈME
    ================================================================ */
    .s-problem {
      background: var(--bg2);
      padding: 100px 0;
    }

    .s-problem .section-h2 { margin-bottom: 48px; max-width: 560px; }

    .problem-list { list-style: none; }

    .problem-item {
      display: flex; align-items: center; gap: 20px;
      padding: 22px 0;
      border-bottom: 1px solid var(--border);
      font-size: 17px; color: var(--text);
    }
    .problem-item:first-child { border-top: 1px solid var(--border); }

    .p-icon {
      width: 40px; height: 40px; border-radius: 10px; flex-shrink: 0;
      background: rgba(244,81,30,0.1);
      display: flex; align-items: center; justify-content: center;
    }
    .p-icon svg { width: 18px; height: 18px; stroke: var(--accent); }

    /* ================================================================
       SECTION 2b — PRODUITS / CE QU'ON CONSTRUIT
    ================================================================ */
    .s-services { background: var(--bg); padding: 100px 0; }
    .s-services .section-h2 { margin-bottom: 12px; }
    .section-sub { font-size: 17px; color: var(--muted); margin-bottom: 52px; max-width: 580px; line-height: 1.65; }

    .services-grid {
      display: grid; grid-template-columns: 1fr 1fr; gap: 20px;
    }

    .srv-card {
      background: var(--bg2); border: 1px solid var(--border);
      border-radius: var(--r); padding: 36px;
      transition: border-color 0.2s, transform 0.2s;
      position: relative; overflow: hidden;
    }
    .srv-card::before {
      content: ''; position: absolute; top: 0; left: 0; right: 0;
      height: 2px; background: var(--accent);
      transform: scaleX(0); transform-origin: left;
      transition: transform 0.3s ease-out;
    }
    .srv-card:hover { border-color: rgba(244,81,30,0.3); transform: translateY(-2px); }
    .srv-card:hover::before { transform: scaleX(1); }

    .srv-tag {
      display: inline-flex; align-items: center;
      padding: 4px 12px; border-radius: 100px;
      font-family: var(--f-mono); font-size: 10px; font-weight: 600;
      letter-spacing: 0.1em; text-transform: uppercase;
      background: rgba(244,81,30,0.08); color: var(--accent);
      border: 1px solid rgba(244,81,30,0.2);
      margin-bottom: 18px;
    }

    .srv-title {
      font-family: var(--f-display); font-size: 21px; font-weight: 700;
      letter-spacing: -0.02em; margin-bottom: 12px; color: var(--text);
    }

    .srv-desc {
      font-size: 15px; color: var(--muted); line-height: 1.75;
      margin-bottom: 24px;
    }

    .srv-metrics {
      display: flex; gap: 24px; flex-wrap: wrap; margin-bottom: 24px;
    }
    .srv-metric strong {
      display: block; font-family: var(--f-display);
      font-size: 17px; font-weight: 800; color: var(--text);
      letter-spacing: -0.02em; line-height: 1.3;
    }
    .srv-metric span {
      font-size: 11px; color: var(--muted); font-family: var(--f-mono);
    }

    .srv-price {
      font-family: var(--f-mono); font-size: 12px; color: var(--muted);
      padding-top: 18px; border-top: 1px solid var(--border);
      display: flex; align-items: center; justify-content: space-between;
    }
    .srv-price strong { color: var(--accent); font-size: 14px; letter-spacing: -0.01em; }

    @media (max-width: 768px) {
      .services-grid { grid-template-columns: 1fr; }
    }

    /* ================================================================
       SECTION 3 — TRANSFORMATION
    ================================================================ */
    .s-transform { padding: 100px 0; background: var(--bg); }

    .s-transform .section-h2 { margin-bottom: 48px; }

    .transform-grid {
      display: grid; grid-template-columns: 1fr 1fr; gap: 20px;
      margin-bottom: 48px;
    }

    .t-card {
      background: var(--bg2); border: 1px solid var(--border);
      border-radius: var(--r); padding: 36px;
    }
    .t-card.before { border-left: 3px solid #EF4444; }
    .t-card.after  { border-left: 3px solid #10B981; }

    .t-label {
      display: flex; align-items: center; gap: 10px;
      font-family: var(--f-mono); font-size: 11px; font-weight: 500;
      letter-spacing: 0.1em; text-transform: uppercase;
      margin-bottom: 20px;
    }
    .t-label.before { color: #EF4444; }
    .t-label.after  { color: #10B981; }

    .t-badge {
      width: 24px; height: 24px; border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-size: 13px; font-weight: 700;
    }
    .before .t-badge { background: rgba(239,68,68,0.15); color: #EF4444; }
    .after  .t-badge { background: rgba(16,185,129,0.15); color: #10B981; }

    .t-card p {
      font-size: 16px; line-height: 1.8; color: var(--muted);
    }
    .t-card p strong { color: var(--text); font-weight: 500; }

    .transform-cta { text-align: center; }

    /* ================================================================
       SECTION 4 — COMMENT ÇA MARCHE
    ================================================================ */
    .s-process { background: var(--bg2); padding: 100px 0; }
    .s-process .section-h2 { margin-bottom: 64px; }

    .process-steps { position: relative; }
    .process-steps::before {
      content: '';
      position: absolute;
      left: 29px; top: 64px; bottom: 64px;
      width: 1px; background: var(--border);
    }

    .p-step {
      display: grid; grid-template-columns: 60px 1fr; gap: 36px;
      padding: 44px 0;
    }
    .p-step:not(:last-child) { border-bottom: 1px solid var(--border); }

    .step-num {
      width: 58px; height: 58px; border-radius: 50%;
      border: 1px solid var(--border); background: var(--bg2);
      display: flex; align-items: center; justify-content: center;
      font-family: var(--f-mono); font-size: 13px; color: var(--accent);
      position: relative; z-index: 1; flex-shrink: 0;
    }

    .p-step h3 {
      font-family: var(--f-display); font-size: 22px; font-weight: 700;
      letter-spacing: -0.02em; margin-bottom: 10px;
    }
    .p-step p { font-size: 16px; line-height: 1.7; color: var(--muted); max-width: 460px; }

    .step-tag {
      display: inline-flex; align-items: center; gap: 6px;
      margin-top: 16px; padding: 6px 14px;
      border: 1px solid var(--border); border-radius: 100px;
      font-size: 12px; font-family: var(--f-mono); color: var(--muted);
    }

    /* ================================================================
       SECTION 5 — PREUVE
    ================================================================ */
    .s-proof { background: var(--bg); padding: 100px 0; }
    .s-proof .section-h2 { margin-bottom: 8px; }
    .s-proof .lead { font-size: 17px; color: var(--muted); margin-bottom: 48px; }

    .demo-card {
      background: var(--bg2); border: 1px solid var(--border);
      border-radius: var(--r); overflow: hidden; margin-bottom: 48px;
    }
    .demo-header {
      padding: 16px 24px; border-bottom: 1px solid var(--border);
      display: flex; align-items: center; justify-content: space-between;
    }
    .demo-dots { display: flex; gap: 7px; }
    .demo-dots span { width: 12px; height: 12px; border-radius: 50%; background: var(--border); }
    .demo-dots span:nth-child(1) { background: #FF5F57; }
    .demo-dots span:nth-child(2) { background: #FEBC2E; }
    .demo-dots span:nth-child(3) { background: #28C840; }
    .demo-url { font-family: var(--f-mono); font-size: 12px; color: var(--muted); }

    .demo-body { padding: 36px 28px; }
    .demo-name { font-family: var(--f-display); font-size: 20px; font-weight: 700; margin-bottom: 8px; }
    .demo-desc { font-size: 14px; color: var(--muted); margin-bottom: 24px; }
    .demo-tags { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 28px; }
    .demo-tag {
      padding: 5px 14px; border: 1px solid var(--border); border-radius: 100px;
      font-size: 12px; font-family: var(--f-mono); color: var(--muted);
    }
    .demo-tag.on { border-color: var(--accent); color: var(--accent); }

    .trust-grid {
      display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px;
      margin-bottom: 48px;
    }
    .trust-card {
      background: var(--bg2); border: 1px solid var(--border);
      border-radius: var(--r); padding: 28px;
    }
    .trust-icon {
      width: 40px; height: 40px; border-radius: 10px;
      background: rgba(244,81,30,0.1);
      display: flex; align-items: center; justify-content: center;
      margin-bottom: 16px;
    }
    .trust-icon svg { width: 18px; height: 18px; stroke: var(--accent); }
    .trust-card h4 { font-family: var(--f-display); font-size: 16px; font-weight: 700; margin-bottom: 8px; }
    .trust-card p { font-size: 14px; color: var(--muted); line-height: 1.6; }

    .tools-row { text-align: center; }
    .tools-row .tools-label {
      font-family: var(--f-mono); font-size: 11px; color: var(--muted);
      letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 18px;
    }
    .tools-pills { display: flex; flex-wrap: wrap; justify-content: center; gap: 8px; }
    .tool-pill {
      padding: 7px 16px; border: 1px solid var(--border); border-radius: 100px;
      font-size: 13px; color: var(--muted); background: var(--bg2);
    }

    /* ================================================================
       SECTION 6 — PRICING
    ================================================================ */
    .s-pricing { background: var(--bg2); padding: 100px 0; }
    .s-pricing .section-h2 { margin-bottom: 8px; }
    .pricing-lead { font-size: 17px; color: var(--muted); margin-bottom: 48px; }

    .pricing-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 32px; }

    .pricing-card {
      background: var(--bg); border: 1px solid var(--border);
      border-radius: var(--r); padding: 40px;
    }
    .pricing-card.featured {
      border-color: var(--accent);
      background: #0E0906;
    }

    .pc-name { font-family: var(--f-display); font-size: 20px; font-weight: 700; margin-bottom: 8px; }
    .pc-desc { font-size: 14px; color: var(--muted); line-height: 1.6; margin-bottom: 32px; }
    .pc-from { font-family: var(--f-mono); font-size: 11px; color: var(--muted); letter-spacing: 0.08em; text-transform: uppercase; }
    .pc-amount {
      font-family: var(--f-display); font-size: 50px; font-weight: 800;
      letter-spacing: -0.04em; line-height: 1.1; color: var(--text);
    }
    .featured .pc-amount { color: var(--accent); }
    .pc-period { font-size: 13px; color: var(--muted); margin-top: 4px; margin-bottom: 32px; }

    .pc-features { list-style: none; display: flex; flex-direction: column; gap: 11px; margin-bottom: 36px; }
    .pc-features li { display: flex; align-items: flex-start; gap: 10px; font-size: 14px; color: var(--muted); line-height: 1.5; }
    .pc-check { color: var(--accent); flex-shrink: 0; font-size: 15px; margin-top: 1px; }

    .pricing-note {
      padding: 24px 28px; border: 1px solid var(--border); border-radius: var(--r);
      background: var(--bg); font-size: 14px; color: var(--muted); line-height: 1.7;
      text-align: center;
    }
    .pricing-note strong { color: var(--text); }

    /* ================================================================
       SECTION 7 — FAQ
    ================================================================ */
    .s-faq { background: var(--bg); padding: 100px 0; }
    .s-faq .section-h2 { margin-bottom: 48px; }

    .faq-wrap { max-width: 700px; }

    .faq-item { border-bottom: 1px solid var(--border); }
    .faq-item:first-child { border-top: 1px solid var(--border); }

    .faq-q {
      width: 100%; background: none; border: none; cursor: pointer;
      padding: 22px 0; display: flex; align-items: center;
      justify-content: space-between; gap: 16px; text-align: left;
      color: var(--text); font-size: 17px; font-weight: 500; font-family: var(--f-body);
    }
    .faq-ic {
      width: 28px; height: 28px; border-radius: 50%; border: 1px solid var(--border);
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0; font-size: 18px; line-height: 1; color: var(--muted);
      transition: transform 0.3s, background 0.3s, border-color 0.3s;
    }
    .faq-item.open .faq-ic {
      transform: rotate(45deg);
      background: var(--accent); border-color: var(--accent); color: #fff;
    }
    .faq-a { max-height: 0; overflow: hidden; transition: max-height 0.35s ease-out; }
    .faq-item.open .faq-a { max-height: 280px; }
    .faq-a p { padding: 0 0 22px; font-size: 15px; line-height: 1.75; color: rgba(250,250,250,0.72); }

    /* ================================================================
       SECTION 8 — CTA FINAL
    ================================================================ */
    .s-cta-final {
      background: var(--bg2); padding: 120px 0;
      text-align: center;
    }
    .s-cta-final h2 {
      font-family: var(--f-display);
      font-size: clamp(30px, 5vw, 54px); font-weight: 800;
      letter-spacing: -0.04em; line-height: 1.1;
      max-width: 620px; margin: 0 auto 24px;
    }
    .cta-sub {
      font-size: 16px; color: var(--muted);
      max-width: 440px; margin: 0 auto 40px; line-height: 1.65;
    }

    /* ================================================================
       FOOTER
    ================================================================ */
    .footer {
      background: var(--bg); border-top: 1px solid var(--border); padding: 44px 0;
    }
    .footer-inner {
      display: flex; align-items: center; justify-content: space-between;
      flex-wrap: wrap; gap: 20px;
    }
    .footer-logo {
      display: flex; align-items: center; gap: 10px;
      text-decoration: none; color: var(--text);
      font-family: var(--f-display); font-weight: 700; font-size: 15px;
    }
    .footer-copy { font-size: 13px; color: var(--muted); }
    .footer-links { display: flex; gap: 24px; }
    .footer-links a { font-size: 13px; color: var(--muted); text-decoration: none; }
    .footer-links a:hover { color: var(--text); }

    /* ================================================================
       RESPONSIVE
    ================================================================ */
    @media (max-width: 768px) {
      .nav-links { display: none; }
      /* Header mobile: logo à gauche, CTA compact "Diagnostic" à droite, burger caché */
      .nav .btn-sm { padding: 8px 14px; font-size: 13px; }
      .nav .btn-sm .cta-full { display: none; }
      .nav .btn-sm .cta-short { display: inline; }
      .nav-burger { display: none !important; }
      /* Logo compact */
      .nav-logo { font-size: 14px; gap: 8px; }
      .nav-logo svg { width: 28px !important; height: 28px !important; }

      .transform-grid { grid-template-columns: 1fr; }
      .trust-grid { grid-template-columns: 1fr; }
      .pricing-grid { grid-template-columns: 1fr; }
      .process-steps::before { display: none; }
      .p-step { grid-template-columns: 48px 1fr; gap: 20px; }
      .footer-inner { flex-direction: column; align-items: flex-start; }

      /* FAQ : questions mieux espacées et contraste texte renforcé */
      .s-faq { padding: 72px 0; }
      .faq-q { padding: 20px 0; font-size: 16px; }
    }
    @media (max-width: 480px) {
      .hero-ctas { flex-direction: column; align-items: flex-start; }
    }

    /* Par défaut (desktop), cacher le label court */
    .nav .btn-sm .cta-short { display: none; }

    /* ================================================================
       HERO WIDGET — show don't tell
    ================================================================ */
    .hero-widget {
      display: none;
      position: absolute;
      right: max(40px, calc((100vw - 1200px) / 2));
      top: 50%; transform: translateY(-50%);
      width: 280px;
      background: var(--bg2);
      border: 1px solid rgba(255,255,255,0.07);
      border-radius: 16px; padding: 22px 24px;
      box-shadow: 0 0 0 1px rgba(244,81,30,0.06) inset, 0 32px 80px rgba(0,0,0,0.6);
      z-index: 3;
      animation: hwFloat 5s ease-in-out infinite;
    }
    @keyframes hwFloat {
      0%,100%{ transform: translateY(-50%) }
      50%{ transform: translateY(calc(-50% - 10px)) }
    }
    @media (min-width: 1100px) { .hero-widget { display: block; } }

    .hw-header {
      display: flex; align-items: center; gap: 8px;
      margin-bottom: 18px; padding-bottom: 14px;
      border-bottom: 1px solid rgba(255,255,255,0.06);
    }
    .hw-dot { width: 7px; height: 7px; border-radius: 50%; background: #10B981; animation: pulse 2s infinite; flex-shrink: 0; }
    .hw-title { font-family: var(--f-mono); font-size: 11px; color: var(--muted); letter-spacing: 0.06em; }

    .hw-item {
      display: flex; align-items: flex-start; gap: 10px;
      padding: 9px 0; border-bottom: 1px solid rgba(255,255,255,0.04);
    }
    .hw-item:last-of-type { border-bottom: none; }
    .hw-check {
      width: 18px; height: 18px; border-radius: 50%;
      background: rgba(16,185,129,0.15); color: #10B981;
      display: flex; align-items: center; justify-content: center;
      font-size: 10px; font-weight: 700; flex-shrink: 0;
    }
    .hw-item strong { display: block; font-size: 13px; font-weight: 500; color: var(--text); line-height: 1.3; }
    .hw-item span { font-size: 11px; color: var(--muted); font-family: var(--f-mono); }
    .hw-footer {
      margin-top: 14px; padding-top: 12px;
      border-top: 1px solid rgba(255,255,255,0.06);
      font-size: 11px; color: var(--muted); font-family: var(--f-mono);
    }

    /* ================================================================
       NAVBAR — HAMBURGER + MOBILE MENU
    ================================================================ */
    .nav-burger {
      display: none;
      background: none; border: none; cursor: pointer;
      padding: 8px; gap: 5px; flex-direction: column;
      align-items: center; justify-content: center;
      z-index: 201;
    }
    .nav-burger span {
      display: block; width: 22px; height: 1.5px;
      background: var(--text);
      transition: transform 0.35s cubic-bezier(0.4,0,0.2,1), opacity 0.25s, width 0.3s;
      transform-origin: center;
    }
    .nav-burger.open span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
    .nav-burger.open span:nth-child(2) { opacity: 0; width: 0; }
    .nav-burger.open span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }

    @media (max-width: 768px) { .nav-burger { display: flex; } }

    /* Mobile menu overlay */
    .mobile-menu {
      position: fixed; inset: 0; z-index: 200;
      background: var(--bg);
      display: flex; flex-direction: column;
      padding: 100px 36px 48px;
      transform: translateX(100%);
      transition: transform 0.45s cubic-bezier(0.4,0,0.2,1);
      pointer-events: none;
    }
    .mobile-menu.open { transform: none; pointer-events: all; }

    .mm-links { display: flex; flex-direction: column; gap: 0; flex: 1; }
    .mm-link {
      display: block; padding: 20px 0;
      border-bottom: 1px solid var(--border);
      font-family: var(--f-display); font-size: 28px; font-weight: 800;
      letter-spacing: -0.03em; color: var(--text);
      text-decoration: none;
      opacity: 0; transform: translateX(24px);
      transition: opacity 0.35s, transform 0.35s, color 0.2s;
    }
    .mm-link:hover { color: var(--accent); }
    .mobile-menu.open .mm-link { opacity: 1; transform: none; }
    .mobile-menu.open .mm-link:nth-child(1) { transition-delay: 0.08s; }
    .mobile-menu.open .mm-link:nth-child(2) { transition-delay: 0.13s; }
    .mobile-menu.open .mm-link:nth-child(3) { transition-delay: 0.18s; }
    .mobile-menu.open .mm-link:nth-child(4) { transition-delay: 0.23s; }
    .mobile-menu.open .mm-link:nth-child(5) { transition-delay: 0.28s; }
    .mm-cta {
      margin-top: 40px; width: 100%;
      opacity: 0; transform: translateY(12px);
      transition: opacity 0.4s 0.32s, transform 0.4s 0.32s;
    }
    .mobile-menu.open .mm-cta { opacity: 1; transform: none; }

    /* ================================================================
       SPLIT SLIDER — AVANT / APRÈS
    ================================================================ */
    .split-wrapper { margin-bottom: 48px; }
    .split-hint {
      display: flex; align-items: center; justify-content: center; gap: 10px;
      font-family: var(--f-mono); font-size: 11px; color: var(--muted);
      letter-spacing: 0.07em; text-transform: uppercase; margin-bottom: 16px;
    }
    .hint-icon { color: var(--accent); font-size: 14px; }

    .split-slider {
      position: relative; border-radius: 20px; overflow: hidden;
      height: 440px; cursor: col-resize; user-select: none;
      border: 1px solid var(--border);
      box-shadow: 0 32px 80px rgba(0,0,0,0.5);
    }

    .split-panel {
      position: absolute; inset: 0;
      display: flex; flex-direction: column;
      padding: 0;
    }
    .split-before { background: #0d0707; }
    .split-after  {
      background: #060d07;
      clip-path: inset(0 0 0 55%);
    }

    /* App chrome (mac-style titlebar) */
    .app-chrome {
      display: flex; align-items: center; gap: 0;
      padding: 11px 16px; flex-shrink: 0;
      border-bottom: 1px solid rgba(255,255,255,0.07);
      background: rgba(0,0,0,0.25);
    }
    .app-dots { display: flex; gap: 6px; margin-right: 14px; }
    .app-dots span { width: 11px; height: 11px; border-radius: 50%; }
    .app-title { font-family: var(--f-mono); font-size: 12px; color: var(--muted); }
    .inbox-count { margin-left: 5px; font-weight: 700; }
    .split-before .inbox-count { color: #EF4444; }
    .split-after  .inbox-count { color: #10B981; }

    /* Panel label strip */
    .panel-label {
      padding: 9px 16px; flex-shrink: 0;
      font-family: var(--f-mono); font-size: 10px; font-weight: 700;
      letter-spacing: 0.14em; text-transform: uppercase;
      display: flex; align-items: center; gap: 8px;
    }
    .split-before .panel-label { background: rgba(239,68,68,0.08); color: #EF4444; border-bottom: 1px solid rgba(239,68,68,0.12); }
    .split-after  .panel-label { background: rgba(16,185,129,0.08); color: #10B981; border-bottom: 1px solid rgba(16,185,129,0.12); }
    .pl-dot { width: 6px; height: 6px; border-radius: 50%; background: currentColor; }

    /* Mail items */
    .mail-items { flex: 1; overflow: hidden; }
    .mail-item {
      display: flex; align-items: center; gap: 12px;
      padding: 13px 16px;
      border-bottom: 1px solid rgba(255,255,255,0.04);
    }
    .mail-unread {
      width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0;
    }
    .split-before .mail-unread { background: #EF4444; box-shadow: 0 0 8px rgba(239,68,68,0.5); animation: urgentPulse 1.4s ease-in-out infinite; }
    .split-after  .mail-unread { background: #10B981; }
    @keyframes urgentPulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:0.5;transform:scale(0.8)} }

    .mail-info { flex: 1; min-width: 0; }
    .mail-from { display: block; font-size: 13px; font-weight: 600; color: var(--text); line-height: 1.3; }
    .mail-sub  { display: block; font-size: 11px; color: var(--muted); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin-top: 1px; }
    .mail-tag {
      flex-shrink: 0; font-family: var(--f-mono); font-size: 10px; font-weight: 700;
      padding: 3px 8px; border-radius: 5px; letter-spacing: 0.03em;
    }
    .mail-tag.danger  { background: rgba(239,68,68,0.12); color: #EF4444; border: 1px solid rgba(239,68,68,0.25); }
    .mail-tag.warning { background: rgba(245,158,11,0.12); color: #F59E0B; border: 1px solid rgba(245,158,11,0.25); }
    .mail-tag.ok      { background: rgba(16,185,129,0.12); color: #10B981; border: 1px solid rgba(16,185,129,0.25); }

    /* Time footer */
    .time-footer {
      display: flex; align-items: center; justify-content: space-between;
      padding: 14px 16px; flex-shrink: 0;
      border-top: 1px solid rgba(255,255,255,0.06);
      background: rgba(0,0,0,0.2);
    }
    .tf-label { font-family: var(--f-mono); font-size: 11px; color: var(--muted); }
    .split-before .tf-num { font-family: var(--f-mono); font-size: 22px; font-weight: 800; color: #EF4444; letter-spacing: -0.02em; }
    .split-after  .tf-num { font-family: var(--f-display); font-size: 22px; font-weight: 800; color: #10B981; letter-spacing: -0.03em; }

    /* AFTER items — animated when triggered */
    .after-item { opacity: 0; transform: translateX(18px); }
    .split-after.animated .after-item {
      animation: afIn 0.45s cubic-bezier(0.16,1,0.3,1) forwards;
    }
    .split-after.animated .after-item.d1 { animation-delay: 0.04s; }
    .split-after.animated .after-item.d2 { animation-delay: 0.13s; }
    .split-after.animated .after-item.d3 { animation-delay: 0.22s; }
    .split-after.animated .after-item.d4 { animation-delay: 0.31s; }
    @keyframes afIn { to { opacity:1; transform:none; } }

    /* Handle */
    .split-handle {
      position: absolute; top: 0; bottom: 0;
      left: 55%; transform: translateX(-50%);
      width: 2px; display: flex; flex-direction: column;
      align-items: center; z-index: 10; cursor: col-resize; pointer-events: all;
    }
    .sh-line { flex: 1; width: 2px; background: rgba(255,255,255,0.18); }
    .sh-pill {
      display: flex; align-items: center; gap: 5px;
      padding: 7px 12px; border-radius: 100px;
      background: var(--text); color: var(--bg);
      font-size: 11px; font-weight: 700; font-family: var(--f-mono);
      white-space: nowrap; flex-shrink: 0;
      box-shadow: 0 4px 20px rgba(0,0,0,0.5);
      letter-spacing: 0.04em;
      transition: background 0.2s;
    }
    .sh-pill:hover { background: #f0f0f0; }
    .sh-pill svg { width: 14px; height: 14px; }

    .split-mobile { display: none; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 48px; }
    @media (max-width: 768px) {
      .split-slider { display: none; }
      .split-mobile { display: grid; }
    }
    @media (max-width: 480px) { .split-mobile { grid-template-columns: 1fr; } }
    .sm-card {
      background: var(--bg2); border-radius: var(--r); padding: 28px 24px;
    }
    .sm-card.before { border-left: 3px solid #EF4444; }
    .sm-card.after  { border-left: 3px solid #10B981; }
    .sm-label { font-family: var(--f-mono); font-size: 10px; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; margin-bottom: 14px; }
    .sm-card.before .sm-label { color: #EF4444; }
    .sm-card.after  .sm-label { color: #10B981; }
    .sm-card p { font-size: 14px; line-height: 1.7; color: var(--muted); }
    .sm-card p strong { color: var(--text); font-weight: 500; }

    /* ================================================================
       CASE STUDY CARD
    ================================================================ */
    .case-card {
      background: var(--bg2); border: 1px solid var(--border);
      border-radius: var(--r); padding: 36px;
      display: grid; grid-template-columns: 1fr auto; gap: 32px; align-items: center;
      margin-bottom: 24px;
      text-decoration: none;
      transition: border-color 0.2s, transform 0.2s;
    }
    .case-card:hover { border-color: rgba(244,81,30,0.4); transform: translateY(-2px); }
    .cc-eyebrow {
      font-family: var(--f-mono); font-size: 10px; color: var(--accent);
      letter-spacing: 0.12em; text-transform: uppercase; margin-bottom: 10px;
    }
    .cc-title { font-family: var(--f-display); font-size: 20px; font-weight: 700; color: var(--text); margin-bottom: 12px; letter-spacing: -0.02em; }
    .cc-meta { font-size: 13px; color: var(--muted); margin-bottom: 20px; }
    .cc-stats { display: flex; gap: 24px; flex-wrap: wrap; }
    .cc-stat strong { display: block; font-family: var(--f-display); font-size: 24px; font-weight: 800; color: var(--text); letter-spacing: -0.03em; }
    .cc-stat span { font-size: 12px; color: var(--muted); }
    .cc-arrow {
      width: 48px; height: 48px; border-radius: 50%;
      border: 1px solid var(--border); display: flex; align-items: center; justify-content: center;
      color: var(--muted); font-size: 18px; flex-shrink: 0;
      transition: background 0.2s, border-color 0.2s, color 0.2s;
    }
    .case-card:hover .cc-arrow { background: var(--accent); border-color: var(--accent); color: #fff; }
    @media (max-width: 600px) { .case-card { grid-template-columns: 1fr; } .cc-arrow { display: none; } }

    /* ================================================================
       PRICING ROI BLOCK
    ================================================================ */
    .roi-block {
      background: var(--bg); border: 1px solid var(--border); border-radius: var(--r);
      padding: 32px 36px; margin-bottom: 40px;
      display: grid; grid-template-columns: 1fr auto; gap: 32px; align-items: center;
    }
    .roi-label { font-family: var(--f-mono); font-size: 10px; color: var(--muted); letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 10px; }
    .roi-calc { font-size: 15px; color: var(--muted); line-height: 1.8; }
    .roi-calc strong { color: var(--text); }
    .roi-highlight {
      text-align: center; flex-shrink: 0;
    }
    .roi-highlight .rh-num { font-family: var(--f-display); font-size: 42px; font-weight: 800; color: var(--accent); letter-spacing: -0.04em; line-height: 1; }
    .roi-highlight .rh-label { font-size: 12px; color: var(--muted); margin-top: 4px; }
    @media (max-width: 640px) { .roi-block { grid-template-columns: 1fr; } }
  </style>
